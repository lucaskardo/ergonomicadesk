# ═══════════════════════════════════════════════════════════════════════════════
# Storefront .env.template — Ergonómica
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Required for production ─────────────────────────────────────────────────

# Medusa Backend
MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_

# Storefront URLs (no trailing slash) — used for SEO canonical/hreflang
NEXT_PUBLIC_BASE_URL=https://ergonomicadesk.com
NEXT_PUBLIC_SITE_URL=https://ergonomicadesk.com

# Default region ISO-2 lowercase (e.g. "pa" for Panama)
NEXT_PUBLIC_DEFAULT_REGION=pa

# NMI Payments — tokenization key (public, used by NMI widget in browser)
NEXT_PUBLIC_NMI_TOKENIZATION_KEY=

# Cloudflare Turnstile (bot protection on checkout)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=7b580fxk
NEXT_PUBLIC_SANITY_DATASET=production

# ⚠️  SANITY_API_READ_TOKEN was previously exposed — rotate before production deploy.
# Create a new "Viewer" token at manage.sanity.io → API → Tokens
SANITY_API_READ_TOKEN=

# Sanity webhook secret — shared between Sanity webhook config and this app
SANITY_REVALIDATE_SECRET=

# Sentry (error monitoring)
SENTRY_AUTH_TOKEN=

# ─── Optional / development only ────────────────────────────────────────────

# Google Tag Manager — leave empty to disable GTM
NEXT_PUBLIC_GTM_ID=

# Meilisearch (instant search)
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_API_KEY=

# Sentry DSN — if unset, Sentry is disabled
NEXT_PUBLIC_SENTRY_DSN=

# Sanity write token — only needed for seed scripts and Studio mutations
SANITY_API_TOKEN=

# ─── Legacy / Unused — kept for reference ────────────────────────────────────
# NEXT_PUBLIC_STRIPE_KEY=
# NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
# NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=
