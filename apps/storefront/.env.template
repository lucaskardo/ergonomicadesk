# ─── Medusa Backend ──────────────────────────────────────────────────────────
# Server-side URL used by Next.js data fetching (never exposed to browser)
MEDUSA_BACKEND_URL=http://localhost:9000

# Client-side URL used in browser (must be public)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key — create in Medusa Admin → Settings → API Keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_

# ─── Storefront URLs ─────────────────────────────────────────────────────────
# Canonical site URL (no trailing slash) — used for SEO canonical/hreflang
NEXT_PUBLIC_BASE_URL=https://ergonomicadesk.com
NEXT_PUBLIC_SITE_URL=https://ergonomicadesk.com

# Default region ISO-2 lowercase (e.g. "pa" for Panama)
NEXT_PUBLIC_DEFAULT_REGION=pa

# ─── NMI Payments ────────────────────────────────────────────────────────────
# Tokenization key (public — used by NMI widget in browser)
NEXT_PUBLIC_NMI_TOKENIZATION_KEY=

# ─── Cloudflare Turnstile (bot protection on checkout) ────────────────────────
# Site key (public) — from Cloudflare dashboard
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret key (server-side) — used to verify Turnstile tokens
TURNSTILE_SECRET_KEY=

# ─── Google Tag Manager ───────────────────────────────────────────────────────
# GTM container ID (e.g. GTM-XXXXXXX). Leave empty to disable GTM.
NEXT_PUBLIC_GTM_ID=

# ─── Meilisearch (search) ────────────────────────────────────────────────────
# Public Meilisearch host (used in browser for instant search)
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700

# Meilisearch search-only API key (public)
NEXT_PUBLIC_MEILISEARCH_API_KEY=

# ─── Sentry (error monitoring) ────────────────────────────────────────────────
# DSN for error reporting — found in Sentry project settings
NEXT_PUBLIC_SENTRY_DSN=

# Auth token for uploading source maps during `next build`
# Generate at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=

# ─── Sanity (CMS) ─────────────────────────────────────────────────────────────
# Project ID and dataset (public — needed by Studio in the browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=7b580fxk
NEXT_PUBLIC_SANITY_DATASET=production

# API read token (server-only) — create in manage.sanity.io → API → Tokens
# Needs "Viewer" permissions minimum. Used by defineLive for Live Content API.
SANITY_API_READ_TOKEN=

# Write token for seed script and Studio mutations
SANITY_API_TOKEN=

# Webhook secret — shared between Sanity webhook config and this app
SANITY_REVALIDATE_SECRET=

# ─── Legacy / Unused — kept for reference ─────────────────────────────────────
# These were in the original Medusa starter but are NOT used by this project:
# NEXT_PUBLIC_STRIPE_KEY=
# NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
# NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=
# REVALIDATE_SECRET=
