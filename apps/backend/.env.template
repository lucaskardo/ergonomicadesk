# ─── CORS ─────────────────────────────────────────────────────────────────────
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000

# ─── Secrets ──────────────────────────────────────────────────────────────────
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/medusa-v2
DB_NAME=medusa-v2

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Storefront (used for order confirmation links, etc.) ─────────────────────
STOREFRONT_URL=https://ergonomicadesk.com

# Public backend URL (used internally for callbacks)
BACKEND_PUBLIC_URL=http://localhost:9000

# ─── Meilisearch ─────────────────────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# ─── NMI Payments ─────────────────────────────────────────────────────────────
# Security key for server-side NMI API calls (private — never expose to client)
NMI_SECURITY_KEY=
NMI_TOKENIZATION_KEY=
# Lane ID for NMI API (optional, some account configs require it)
NMI_API_LANE=
# 3D Secure mode: "best_effort" (default) or "strict"
NMI_3DS_MODE=best_effort

# ─── Cloudflare Turnstile (server-side verification) ─────────────────────────
# Secret key used to verify Turnstile tokens during NMI charge
TURNSTILE_SECRET_KEY=

# ─── Meta (Facebook) CAPI ────────────────────────────────────────────────────
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Test event code — only set in staging/dev to use Meta Test Events tool
META_TEST_EVENT_CODE=

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=
# From address must be a verified domain in Resend
RESEND_FROM_EMAIL=hola@ergonomicadesk.com
# Admin notification recipient
ADMIN_NOTIFICATION_EMAIL=admin@ergonomicadesk.com

# ─── Cloudflare R2 (file storage) ─────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://pub-<token>.r2.dev

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Backend Sentry DSN — if unset, Sentry is disabled entirely
SENTRY_DSN=

# ─── SEO / IndexNow ───────────────────────────────────────────────────────────
# API key for IndexNow instant indexing (Bing, Yandex)
INDEXNOW_API_KEY=
