# =============================================================================
# ergonomicadesk.com — Variables de entorno
#
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env.local
# 2. Llena cada valor en .env.local con tus credentials reales
# 3. NUNCA commitees .env.local a git (ya está en .gitignore)
# =============================================================================

# --- Base de datos (PostgreSQL) ---
DATABASE_URL=postgres://medusa:medusa@localhost:5432/medusa

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Medusa backend ---
COOKIE_SECRET=cambia_esto_en_produccion_usa_string_largo_aleatorio
JWT_SECRET=cambia_esto_en_produccion_usa_otro_string_largo_aleatorio
MEDUSA_BACKEND_URL=http://localhost:9000
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:3000

# --- NMI Pagos ---
# Clave PUBLICA (segura para el frontend)
NEXT_PUBLIC_NMI_TOKENIZATION_KEY=tu_tokenization_key_de_nmi
# Clave PRIVADA (solo backend, NUNCA exponer al frontend)
NMI_SECURITY_KEY=tu_security_key_de_nmi

# --- QuickBooks Online ---
QB_CLIENT_ID=tu_quickbooks_client_id
QB_CLIENT_SECRET=tu_quickbooks_client_secret
QB_REDIRECT_URI=http://localhost:9000/custom/webhooks/quickbooks/callback
QB_ENVIRONMENT=sandbox

# --- Cloudflare R2 (almacenamiento de imagenes) ---
CLOUDFLARE_R2_ACCESS_KEY=tu_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=tu_r2_secret_key
CLOUDFLARE_R2_BUCKET=ergonomicadesk-media
CLOUDFLARE_R2_ENDPOINT=https://tu-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://media.ergonomicadesk.com

# --- Cloudflare Turnstile (proteccion anti-bot) ---
# Clave PUBLICA (segura para frontend)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=tu_turnstile_site_key
# Clave PRIVADA (solo backend)
TURNSTILE_SECRET_KEY=tu_turnstile_secret_key

# --- Resend (emails transaccionales) ---
RESEND_API_KEY=tu_resend_api_key
RESEND_FROM_EMAIL=pedidos@ergonomicadesk.com

# --- Sanity CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID=tu_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=tu_sanity_api_token
NEXT_PUBLIC_SANITY_STUDIO_URL=/studio
SANITY_WEBHOOK_SECRET=tu_sanity_webhook_secret

# --- Meilisearch (busqueda de productos) ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=dev-master-key-cambia-en-produccion
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=tu_search_only_api_key

# --- PostHog (analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=tu_posthog_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry (error tracking) ---
SENTRY_DSN_BACKEND=tu_sentry_dsn_backend
NEXT_PUBLIC_SENTRY_DSN=tu_sentry_dsn_storefront

# --- Revalidacion (secreto compartido entre backend y storefront) ---
REVALIDATION_SECRET=cambia_esto_en_produccion_string_aleatorio
STOREFRONT_URL=http://localhost:3000
